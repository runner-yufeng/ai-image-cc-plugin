    "cli",
    "gemini",
    "nano-banana",
    "imagen",
    "vertex-ai",
    "openai",
    "gpt-image-1",
    "claude-code"
  ],
  "license": "MIT",
  "author": "runner-yufeng",
  "dependencies": {
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/google-vertex": "^3.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "ai": "^6.0.0",
